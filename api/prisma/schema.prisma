generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AgentType {
  scout
  risk
  executor
  audit
}

enum SignalStatus {
  pending
  approved
  rejected
  executing
  executed
  failed
}

enum SessionStatus {
  pending
  active
  expired
  rejected
}

enum AlertSeverity {
  info
  warning
  critical
}

model User {
  id             String     @id @default(cuid())
  walletAddress  String     @unique
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  positions      Position[]
  deposits       Deposit[]
}

model Deposit {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  chainId     Int
  txHash      String?
  token       String
  amountUsdc  Decimal  @db.Decimal(20, 6)
  destination String?
  createdAt   DateTime @default(now())

  @@index([userId])
}

model Agent {
  id                String     @id @default(cuid())
  did               String     @unique
  type              AgentType
  vaultAddress      String
  passportSessionId String?
  online            Boolean    @default(false)
  spendingUsedUsdc  Decimal    @db.Decimal(20, 6) @default(0)
  spendingCapUsdc   Decimal    @db.Decimal(20, 6) @default(0)
  poaiScore         Decimal    @db.Decimal(20, 6) @default(0)
  lastActionAt      DateTime?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  signals Signal[] @relation("ScoutSignals")
}

model Signal {
  id                  String       @id @default(cuid())
  scoutDid            String
  scout               Agent        @relation("ScoutSignals", fields: [scoutDid], references: [did])
  srcChain            Int
  dstChain            Int
  srcProtocol         String
  dstProtocol         String
  netDeltaApy         Decimal      @db.Decimal(12, 6)
  suggestedAmountUsdc Decimal      @db.Decimal(20, 6)
  status              SignalStatus @default(pending)
  riskDecisionReason  String?
  txHash              String?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  execution        Execution?
  riskInstruction  RiskInstruction?
  workflowEvents   WorkflowEvent[]
  x402Payments     X402Payment[]
  relayerMessages  RelayerMessage[]
}

model RiskInstruction {
  id                 String   @id
  signalId           String   @unique
  signal             Signal   @relation(fields: [signalId], references: [id], onDelete: Cascade)
  riskDid            String
  executorDid        String
  approved           Boolean
  reason             String
  sourceSignalHash   String?
  paymentTxHash      String?
  signature          String?
  payload            Json
  createdAt          DateTime @default(now())

  @@index([riskDid])
  @@index([executorDid])
}

model Execution {
  id          String    @id @default(cuid())
  signalId    String    @unique
  signal      Signal    @relation(fields: [signalId], references: [id])
  instructionId String?
  executorDid String
  txHash      String
  lzMessageId String?
  status      String
  slippageBps Int?
  paymentTxHash String?
  payload     Json?
  createdAt   DateTime  @default(now())
}

model WorkflowEvent {
  id             String   @id @default(cuid())
  signalId       String?
  signal         Signal?  @relation(fields: [signalId], references: [id], onDelete: Cascade)
  stream         String
  streamEventId  String
  eventType      String
  agentDid       String?
  agentType      String?
  title          String
  summary        String
  txHash         String?
  paymentTxHash  String?
  chainId        Int?
  chainOfThought Json?
  verdict        Json?
  verdictSummary String?
  llmModel       String?
  payload        Json
  occurredAt     DateTime @default(now())
  createdAt      DateTime @default(now())

  @@unique([stream, streamEventId])
  @@index([signalId, occurredAt])
  @@index([agentDid])
  @@index([txHash])
  @@index([paymentTxHash])
}

model AgentDeliberation {
  id             String    @id @default(cuid())
  signalId       String?
  agentType      AgentType
  agentDid       String?
  step           String
  llmModel       String
  chainOfThought Json
  verdict        Json
  verdictSummary String
  rawContent     String?   @db.Text
  createdAt      DateTime  @default(now())

  @@index([signalId, agentType])
}

model X402Payment {
  id             String   @id @default(cuid())
  signalId       String?
  signal         Signal?  @relation(fields: [signalId], references: [id], onDelete: SetNull)
  instructionId  String?
  fromDid        String?
  toDid          String
  amountWei      String
  asset          String
  network        String
  memo           String?
  txHash         String   @unique
  payload        Json?
  createdAt      DateTime @default(now())

  @@index([signalId])
  @@index([fromDid])
  @@index([toDid])
}

model RelayerMessage {
  id                String   @id @default(cuid())
  signalId          String?
  signal            Signal?  @relation(fields: [signalId], references: [id], onDelete: SetNull)
  messageId         String   @unique
  originDomain      Int
  destinationDomain Int
  recipient         String
  dispatchTxHash    String?
  deliveryTxHash    String?
  status            String
  payload           Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([signalId])
  @@index([dispatchTxHash])
  @@index([deliveryTxHash])
}

model Position {
  id           String   @id @default(cuid())
  userId       String?
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  chainId      Int
  chainName    String
  protocol     String
  asset        String
  amountUsdc   Decimal  @db.Decimal(20, 6)
  apy          Decimal  @db.Decimal(8, 4)
  healthFactor Decimal  @db.Decimal(8, 4)
  lastUpdated  DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
}

model VaultHolding {
  id            String   @id @default(cuid())
  userId        String?
  ownerWallet   String?
  vaultAddress  String
  chainId       Int
  chainName     String
  protocol      String
  token         String
  balanceRaw    String
  decimals      Int
  amountUsdc    Decimal  @db.Decimal(20, 6)
  sourceTxHash  String?
  updatedAt     DateTime @updatedAt
  createdAt     DateTime @default(now())

  @@unique([ownerWallet, vaultAddress, chainId, protocol, token])
  @@index([ownerWallet])
  @@index([userId])
}

model Session {
  id                String        @id @default(cuid())
  externalSessionId String?       @unique
  agentDid          String
  maxAmountPerTxUsdc Decimal      @db.Decimal(20, 6)
  maxTotalAmountUsdc Decimal      @db.Decimal(20, 6)
  usedAmountUsdc    Decimal       @db.Decimal(20, 6) @default(0)
  ttlSeconds        Int
  status            SessionStatus @default(pending)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
}

model AttributionRecord {
  id          String   @id @default(cuid())
  agentDid    String
  actionType  String
  inputHash   String
  outcomeHash String
  valueDelta  Decimal  @db.Decimal(20, 6)
  epochId     Int
  blockNumber BigInt?
  createdAt   DateTime @default(now())
}

model Epoch {
  id               Int      @id
  startBlock       BigInt?
  endBlock         BigInt?
  totalRewardsKite Decimal  @db.Decimal(20, 6) @default(0)
  status           String   @default("open")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model SpendingWindow {
  id           String   @id @default(cuid())
  agentDid     String
  windowStart  DateTime
  windowEnd    DateTime
  totalSpentUsdc Decimal @db.Decimal(20, 6)
  capUsdc      Decimal @db.Decimal(20, 6)
  createdAt    DateTime @default(now())
}

model ScoutMarketplace {
  id                   String   @id @default(cuid())
  did                  String   @unique
  didHashHex           String   @default("")
  ownerAddress         String
  vaultAddress         String   @default("")
  bondAmountWei        String   @default("0")
  chainId              Int      @default(2368)
  registrationTxHash   String?
  status               String
  stakeUsdc            Decimal  @db.Decimal(20, 6) @default(0)
  reputationScore      Decimal  @db.Decimal(20, 6) @default(0)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  purchases            ScoutPurchase[]

  @@index([ownerAddress])
}

model ScoutPurchase {
  id                     String           @id @default(cuid())
  scoutMarketplaceId     String
  scoutMarketplace       ScoutMarketplace @relation(fields: [scoutMarketplaceId], references: [id], onDelete: Cascade)
  buyerWallet            String
  amountWei              String
  paymentTxHash          String           @unique
  chainId                Int              @default(2368)
  bindingSecretHash      String
  bindingSecretLast4     String           @default("")
  redisUrl               String?
  scoutSignalStreamKey   String?
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt

  @@unique([scoutMarketplaceId, buyerWallet])
  @@index([scoutMarketplaceId])
  @@index([buyerWallet])
}

model ScoutRegisterNonce {
  nonce         String   @id
  expiresAt     DateTime
  deadlineUnix  Int
  used          Boolean  @default(false)
}

model ScoutPayout {
  id         String   @id @default(cuid())
  scoutDid   String
  epochId    Int
  amountUsdc Decimal  @db.Decimal(20, 6)
  status     String
  txHash     String?
  createdAt  DateTime @default(now())
}

model Alert {
  id         String        @id @default(cuid())
  type       String
  severity   AlertSeverity
  message    String
  resolvedAt DateTime?
  createdAt  DateTime      @default(now())
}
