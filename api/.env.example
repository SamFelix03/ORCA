# Copy to api/.env and fill values below.
# Deployments, server defaults, marketplace, stub manifest path, spoke RPC map:
#   config/orca.api.json  (template: config/orca.api.example.json)
# Optional alternate file: ORCA_API_CONFIG=/path/to/orca.api.json
# .env always wins over the JSON file for any key you set here.

# --- Secrets (required when STRICT_MODE=true, the default) ---
WEBHOOK_SECRET=change-me-generate-a-long-random-secret
JWT_SECRET=change-me-generate-a-long-random-secret
ORCA_INTERNAL_API_KEY=orca-dev-internal

# --- Infrastructure (environment-specific) ---
DATABASE_URL=postgresql://orca:pass@localhost:5432/orca
REDIS_URL=redis://localhost:6379
KITE_RPC_URL=https://rpc-testnet.gokite.ai


# --- Optional flags ---
# STRICT_MODE=true
# NODE_ENV=development

# --- Optional: treasury / multisig reads ---
# TREASURY_MULTISIG_ADDRESS=
# TREASURY_SIGNERS=

# --- Optional: override static config from orca.api.json ---
# ORCA_API_CONFIG=
# PORT=4000
# CORS_ORIGIN=http://localhost:3000
# PIEUSD_TOKEN_ADDRESS=
# ORCA_REGISTRY_ADDRESS=
