# Four-chain trust maps for Hyperlane / OApp / RemoteAdapter (domain:address_or_bytes32, comma-separated)
# HYP_TRUSTED_REMOTES — ORCAOApp mailbox peers: REMOTE RemoteAdapter ON THAT DOMAIN (padded bytes32 OK), NEVER warp routers
# HYP_TRUSTED_SENDERS — hub ORCAOApp on domain 2368 (after pnpm sync:spoke-config + pnpm hyperlane:wire-trust)
HYP_TRUSTED_REMOTES=421614:0x81C7750902Ea8fd2b0Ff7090E6C8f46Dfd924C24,84532:0x54F9c65456c1064E37D9BBeD2da692bA2DC82F8a,11155420:0x9bb2363810156f7b32b255677e8C1852AC1F95E6,11155111:0xc6e13BE404340A944C7a1BB5B3a10b68Eaefae80
