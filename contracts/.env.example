# Override path to Hyperlane snapshot JSON (default: repo hyperlane/outputs/snapshots/orca-integration.latest.json)
HYPERLANE_INTEGRATION_SNAPSHOT=../hyperlane/outputs/snapshots/orca-integration.latest.json
# deploy-remote-stubs.ts / deploy-spoke.ts: underlying ERC20 for the target chain (e.g. USDT)
# Kite testnet faucet USDT (yield / stubs); NOT PIEUSD (payments).
ORCA_UNDERLYING_TOKEN=0x0fF5393387ad2f9f691FD6Fd28e07E3969e27e63
# deploy-spoke.ts only: this chain’s Hyperlane mailbox (same values as HYP_MAILBOX_* in this repo)
