# Copy to contracts/.env and fill values below.
# RPC endpoints, Hyperlane mailboxes/trust, deployments, spending policy, relayer tuning:
#   config/orca.contracts.json  (template: config/orca.contracts.example.json)
# Optional alternate file: ORCA_CONTRACTS_CONFIG=/path/to/orca.contracts.json
# .env always wins over the JSON file for any key you set here.

# --- Secrets (never commit) ---
DEPLOYER_PRIVATE_KEY=
# Relayer uses RELAYER_PRIVATE_KEY when set; otherwise DEPLOYER_PRIVATE_KEY

# Optional alias used by some scripts
# PRIVATE_KEY=

# --- Optional: one-off script overrides (not in orca.contracts.json) ---
# HYP_DEST=sepolia
# AMOUNT=1000000000000000000
# RECIPIENT=
# INTERCHAIN_GAS_WEI=0
# E2E_SKIP_WIRE=1
# VAULT_TX_HASH=

# --- Optional: register agents on registry (needs agents/.env keys + DIDs) ---
# SCOUT_DID=
# SCOUT_PRIVATE_KEY=
# RISK_AGENT_DID=
# RISK_PRIVATE_KEY=
# EXECUTOR_AGENT_DID=
# EXECUTOR_PRIVATE_KEY=
# AUDIT_AGENT_DID=
# AUDIT_PRIVATE_KEY=

# --- Optional: override static config from orca.contracts.json ---
# ORCA_CONTRACTS_CONFIG=
# INITIAL_OWNER=
# HYP_TRUSTED_REMOTES=
# RELAYER_EXTRA_RECIPIENTS=
# REMOTE_ADAPTER_COLLATERAL_TOKEN=
# SCOUT_STAKE_RECIPIENT=
