# Exact URL kpass will POST to (must match agents X402_SERVICE_URL + X402_EXECUTE_PATH).
# Local: http://127.0.0.1:8099/execute
# Remote: https://YOUR_SUBDOMAIN.ngrok-free.app/execute
PUBLIC_RESOURCE_URL=http://127.0.0.1:8099/execute

PORT=8099
HOST=0.0.0.0
EXECUTE_PATH=/execute

# Merchant wallet on Kite testnet (required when X402_PROVIDER_STUB=false).
X402_PAY_TO=

# Token + pricing (matches agents X402_* where applicable).
X402_ASSET_ADDRESS=0x0fF5393387ad2f9f691FD6Fd28e07E3969e27e63
X402_MAX_AMOUNT_REQUIRED_WEI=1000000
X402_MAX_TIMEOUT_SECONDS=300
X402_MERCHANT_NAME=ORCA agent micropayment rail

# CAIP-2 network for Pieverse `scheme: exact` (default eip155:2368 = Kite testnet).
# X402_CAIP_NETWORK=eip155:2368
# Or set KITE_CHAIN_ID=2368 to derive eip155:${KITE_CHAIN_ID}.

# true = synthetic txHash (no Pieverse). false = POST /v2/verify then /v2/settle.
X402_PROVIDER_STUB=true
FACILITATOR_URL=https://facilitator.pieverse.io

# Optional: skip verify if troubleshooting (default false).
X402_SKIP_VERIFY=false

# Log decoded X-Payment top-level keys + short hash only (default false).
X402_DEBUG_PAYMENT_SHAPE=false

# Optional JSON object merged into facilitator `paymentRequirements.extra`.
# X402_PAYMENT_EXTRA_JSON={"name":"USDC","version":"2"}
