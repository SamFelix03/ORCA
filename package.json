{
  "name": "orca-monorepo",
  "private": true,
  "packageManager": "pnpm@10.19.0",
  "scripts": {
    "dev:api": "pnpm --dir api dev",
    "dev:frontend": "pnpm --dir frontend dev",
    "dev": "pnpm -r --parallel --filter @orca/api --filter frontend dev",
    "build:frontend": "pnpm --dir frontend build",
    "build:contracts": "pnpm --dir contracts build",
    "lint:frontend": "pnpm --dir frontend lint"
  }
}
