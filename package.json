{
  "name": "orca-monorepo",
  "private": true,
  "packageManager": "pnpm@10.19.0",
  "scripts": {
    "dev:x402-provider": "pnpm --filter @orca/x402-provider dev",
    "dev:api": "pnpm --dir api dev",
    "dev:frontend": "pnpm --dir frontend dev",
    "dev": "pnpm -r --parallel --filter @orca/api --filter frontend dev",
    "dev:full": "node scripts/dev-full.mjs",
    "build:frontend": "pnpm --dir frontend build",
    "build:contracts": "pnpm --dir contracts build",
    "lint:frontend": "pnpm --dir frontend lint",
    "db:migrate": "pnpm --dir api prisma:migrate",
    "db:setup": "node scripts/setup-db.mjs",
    "db:up": "docker compose -f infra/docker-compose.yml up -d postgres redis",
    "test:agents": "cd agents && python -m pytest tests -q",
    "test:api": "pnpm --dir api test"
  }
}
